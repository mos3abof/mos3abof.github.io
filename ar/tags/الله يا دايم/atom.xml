        <content type="html" xml:base="https://mosab.co.uk/ar/blog/straight-path/">
&lt;div class=&quot;py-6 px-8 my-8 rounded-lg border shadow-sm quran-verse border-teal-600&#x2F;40 bg-teal-50&#x2F;30 dark:bg-teal-950&#x2F;20&quot;
  dir=&quot;rtl&quot; style=&quot;font-family: &#x27;Amiri Quran&#x27;, serif; font-size: 1.6rem;&quot;&gt;
  &lt;div class=&quot;leading-loose text-right quran-text text-slate-800 dark:text-slate-100&quot;&gt;
    ﴿سَيَقُولُ السُّفَهَاءُ مِنَ النَّاسِ مَا وَلَّاهُمْ عَنْ
قِبْلَتِهِمُ الَّتِي كَانُوا عَلَيْهَا قُلْ لِلَّهِ الْمَشْرِقُ
وَالْمَغْرِبُ يَهْدِي مَنْ يَشَاءُ إِلَى صِرَاطٍ مُسْتَقِيمٍ﴾
  &lt;&#x2F;div&gt;
  
  &lt;p class=&quot;mt-4 font-mono text-sm text-center text-teal-700 dark:text-teal-400&quot; dir=&quot;ltr&quot;&gt;
    &amp;#x5B; البقرة : ١٤٢ &amp;#x5D;
  &lt;&#x2F;p&gt;
  
  
&lt;&#x2F;div&gt;

&lt;div class=&quot;py-6 px-8 my-8 rounded-lg border shadow-sm quran-verse border-teal-600&#x2F;40 bg-teal-50&#x2F;30 dark:bg-teal-950&#x2F;20&quot;
  dir=&quot;rtl&quot; style=&quot;font-family: &#x27;Amiri Quran&#x27;, serif; font-size: 1.6rem;&quot;&gt;
  &lt;div class=&quot;leading-loose text-right quran-text text-slate-800 dark:text-slate-100&quot;&gt;
    ﴿كَانَ النَّاسُ أُمَّةً وَاحِدَةً فَبَعَثَ اللَّهُ النَّبِيِّينَ
مُبَشِّرِينَ وَمُنْذِرِينَ وَأَنْزَلَ مَعَهُمُ الْكِتَابَ بِالْحَقِّ
لِيَحْكُمَ بَيْنَ النَّاسِ فِيمَا اخْتَلَفُوا فِيهِ وَمَا
اخْتَلَفَ فِيهِ إِلَّا الَّذِينَ أُوتُوهُ مِنْ بَعْدِ مَا جَاءَتْهُمُ
الْبَيِّنَاتُ بَغْيًا بَيْنَهُمْ فَهَدَى اللَّهُ الَّذِينَ آمَنُوا لِمَا
اخْتَلَفُوا فِيهِ مِنَ الْحَقِّ بِإِذْنِهِ وَاللَّهُ
يَهْدِي مَنْ يَشَاءُ إِلَى صِرَاطٍ مُسْتَقِيمٍ﴾
  &lt;&#x2F;div&gt;
  
  &lt;p class=&quot;mt-4 font-mono text-sm text-center text-teal-700 dark:text-teal-400&quot; dir=&quot;ltr&quot;&gt;
    &amp;#x5B; البقرة : ٢١٣ &amp;#x5D;
  &lt;&#x2F;p&gt;
  
  
&lt;&#x2F;div&gt;

&lt;div class=&quot;py-6 px-8 my-8 rounded-lg border shadow-sm quran-verse border-teal-600&#x2F;40 bg-teal-50&#x2F;30 dark:bg-teal-950&#x2F;20&quot;
  dir=&quot;rtl&quot; style=&quot;font-family: &#x27;Amiri Quran&#x27;, serif; font-size: 1.6rem;&quot;&gt;
  &lt;div class=&quot;leading-loose text-right quran-text text-slate-800 dark:text-slate-100&quot;&gt;
    ﴿إِنَّ اللَّهَ رَبِّي وَرَبُّكُمْ فَاعْبُدُوهُ هَذَا صِرَاطٌ مُسْتَقِيمٌ﴾
  &lt;&#x2F;div&gt;
  
  &lt;p class=&quot;mt-4 font-mono text-sm text-center text-teal-700 dark:text-teal-400&quot; dir=&quot;ltr&quot;&gt;
    &amp;#x5B; آل عمران : ٥١ &amp;#x5D;
  &lt;&#x2F;p&gt;
  
  
&lt;&#x2F;div&gt;

&lt;div class=&quot;py-6 px-8 my-8 rounded-lg border shadow-sm quran-verse border-teal-600&#x2F;40 bg-teal-50&#x2F;30 dark:bg-teal-950&#x2F;20&quot;
  dir=&quot;rtl&quot; style=&quot;font-family: &#x27;Amiri Quran&#x27;, serif; font-size: 1.6rem;&quot;&gt;
  &lt;div class=&quot;leading-loose text-right quran-text text-slate-800 dark:text-slate-100&quot;&gt;
    ﴿وَكَيْفَ تَكْفُرُونَ وَأَنْتُمْ تُتْلَى عَلَيْكُمْ آيَاتُ اللَّهِ
وَفِيكُمْ رَسُولُهُ وَمَنْ يَعْتَصِم بِاللَّهِ فَقَدْ هُدِيَ إِلَى
صِرَاطٍ مُسْتَقِيمٍ﴾
  &lt;&#x2F;div&gt;
  
  &lt;p class=&quot;mt-4 font-mono text-sm text-center text-teal-700 dark:text-teal-400&quot; dir=&quot;ltr&quot;&gt;
    &amp;#x5B; آل عمران : ١٠١ &amp;#x5D;
  &lt;&#x2F;p&gt;
  
  
&lt;&#x2F;div&gt;

&lt;div class=&quot;py-6 px-8 my-8 rounded-lg border shadow-sm quran-verse border-teal-600&#x2F;40 bg-teal-50&#x2F;30 dark:bg-teal-950&#x2F;20&quot;
  dir=&quot;rtl&quot; style=&quot;font-family: &#x27;Amiri Quran&#x27;, serif; font-size: 1.6rem;&quot;&gt;
  &lt;div class=&quot;leading-loose text-right quran-text text-slate-800 dark:text-slate-100&quot;&gt;
    ﴿يَهْدِي بِهِ اللَّهُ مَنِ اتَّبَعَ رِضْوَانَهُ سُبُلَ
السَّلَامِ وَيُخْرِجُهُمْ مِنَ الظُّلُمَاتِ إِلَى النُّورِ بِإِذْنِهِ
وَيَهْدِيهِمْ إِلَى صِرَاطٍ مُسْتَقِيمٍ﴾
  &lt;&#x2F;div&gt;
  
  &lt;p class=&quot;mt-4 font-mono text-sm text-center text-teal-700 dark:text-teal-400&quot; dir=&quot;ltr&quot;&gt;
    &amp;#x5B; المائدة : ١٦ &amp;#x5D;
  &lt;&#x2F;p&gt;
  
  
&lt;&#x2F;div&gt;

&lt;div class=&quot;py-6 px-8 my-8 rounded-lg border shadow-sm quran-verse border-teal-600&#x2F;40 bg-teal-50&#x2F;30 dark:bg-teal-950&#x2F;20&quot;
  dir=&quot;rtl&quot; style=&quot;font-family: &#x27;Amiri Quran&#x27;, serif; font-size: 1.6rem;&quot;&gt;
  &lt;div class=&quot;leading-loose text-right quran-text text-slate-800 dark:text-slate-100&quot;&gt;
    ﴿وَالَّذِينَ كَذَّبُوا بِآيَاتِنَا صُمٌّ وَبُكْمٌ فِي الظُّلُمَاتِ
مَنْ يَشَإِ اللَّهُ يُضْلِلْهُ وَمَنْ يَشَأْ يَجْعَلْهُ عَلَى
صِرَاطٍ مُسْتَقِيمٍ﴾
  &lt;&#x2F;div&gt;
  
  &lt;p class=&quot;mt-4 font-mono text-sm text-center text-teal-700 dark:text-teal-400&quot; dir=&quot;ltr&quot;&gt;
    &amp;#x5B; الأنعام : ٣٩ &amp;#x5D;
  &lt;&#x2F;p&gt;
  
  
&lt;&#x2F;div&gt;

&lt;div class=&quot;py-6 px-8 my-8 rounded-lg border shadow-sm quran-verse border-teal-600&#x2F;40 bg-teal-50&#x2F;30 dark:bg-teal-950&#x2F;20&quot;
  dir=&quot;rtl&quot; style=&quot;font-family: &#x27;Amiri Quran&#x27;, serif; font-size: 1.6rem;&quot;&gt;
  &lt;div class=&quot;leading-loose text-right quran-text text-slate-800 dark:text-slate-100&quot;&gt;
    ﴿وَمِنْ آبَائِهِمْ وَذُرِّيَّاتِهِمْ وَإِخْوَانِهِمْ
وَاجْتَبَيْنَاهُمْ وَهَدَيْنَاهُمْ إِلَى صِرَاطٍ مُسْتَقِيمٍ﴾
  &lt;&#x2F;div&gt;
  
  &lt;p class=&quot;mt-4 font-mono text-sm text-center text-teal-700 dark:text-teal-400&quot; dir=&quot;ltr&quot;&gt;
    &amp;#x5B; الأنعام : ٨٧ &amp;#x5D;
  &lt;&#x2F;p&gt;
  
  
&lt;&#x2F;div&gt;

&lt;div class=&quot;py-6 px-8 my-8 rounded-lg border shadow-sm quran-verse border-teal-600&#x2F;40 bg-teal-50&#x2F;30 dark:bg-teal-950&#x2F;20&quot;
  dir=&quot;rtl&quot; style=&quot;font-family: &#x27;Amiri Quran&#x27;, serif; font-size: 1.6rem;&quot;&gt;
  &lt;div class=&quot;leading-loose text-right quran-text text-slate-800 dark:text-slate-100&quot;&gt;
    ﴿قُلْ إِنَّنِي هَدَانِي رَبِّي إِلَى صِرَاطٍ مُسْتَقِيمٍ دِينًا قِيَمًا
مِلَّةَ إِبْرَاهِيمَ حَنِيفًا وَمَا كَانَ مِنَ الْمُشْرِكِينَ﴾
  &lt;&#x2F;div&gt;
  
  &lt;p class=&quot;mt-4 font-mono text-sm text-center text-teal-700 dark:text-teal-400&quot; dir=&quot;ltr&quot;&gt;
    &amp;#x5B; الأنعام : ١٦١ &amp;#x5D;
  &lt;&#x2F;p&gt;
  
  
&lt;&#x2F;div&gt;

&lt;div class=&quot;py-6 px-8 my-8 rounded-lg border shadow-sm quran-verse border-teal-600&#x2F;40 bg-teal-50&#x2F;30 dark:bg-teal-950&#x2F;20&quot;
  dir=&quot;rtl&quot; style=&quot;font-family: &#x27;Amiri Quran&#x27;, serif; font-size: 1.6rem;&quot;&gt;
  &lt;div class=&quot;leading-loose text-right quran-text text-slate-800 dark:text-slate-100&quot;&gt;
    ﴿وَاللَّهُ يَدْعُو إِلَى دَارِ السَّلَامِ وَيَهْدِي مَنْ يَشَاءُ إِلَى صِرَاطٍ مُسْتَقِيمٍ﴾
  &lt;&#x2F;div&gt;
  
  &lt;p class=&quot;mt-4 font-mono text-sm text-center text-teal-700 dark:text-teal-400&quot; dir=&quot;ltr&quot;&gt;
    &amp;#x5B; يونس : ٢٥ &amp;#x5D;
  &lt;&#x2F;p&gt;
  
  
&lt;&#x2F;div&gt;

&lt;div class=&quot;py-6 px-8 my-8 rounded-lg border shadow-sm quran-verse border-teal-600&#x2F;40 bg-teal-50&#x2F;30 dark:bg-teal-950&#x2F;20&quot;
  dir=&quot;rtl&quot; style=&quot;font-family: &#x27;Amiri Quran&#x27;, serif; font-size: 1.6rem;&quot;&gt;
  &lt;div class=&quot;leading-loose text-right quran-text text-slate-800 dark:text-slate-100&quot;&gt;
    ﴿إِنِّي تَوَكَّلْتُ عَلَى اللَّهِ رَبِّي وَرَبِّكُمْ مَا مِنْ دَابَّةٍ إِلَّا
هُوَ آخِذٌ بِنَاصِيَتِهَا إِنَّ رَبِّي عَلَى صِرَاطٍ مُسْتَقِيمٍ﴾
  &lt;&#x2F;div&gt;
  
  &lt;p class=&quot;mt-4 font-mono text-sm text-center text-teal-700 dark:text-teal-400&quot; dir=&quot;ltr&quot;&gt;
    &amp;#x5B; هود : ٥٦ &amp;#x5D;
  &lt;&#x2F;p&gt;
  
  
&lt;&#x2F;div&gt;

&lt;div class=&quot;py-6 px-8 my-8 rounded-lg border shadow-sm quran-verse border-teal-600&#x2F;40 bg-teal-50&#x2F;30 dark:bg-teal-950&#x2F;20&quot;
  dir=&quot;rtl&quot; style=&quot;font-family: &#x27;Amiri Quran&#x27;, serif; font-size: 1.6rem;&quot;&gt;
  &lt;div class=&quot;leading-loose text-right quran-text text-slate-800 dark:text-slate-100&quot;&gt;
    ﴿وَضَرَبَ اللَّهُ مَثَلًا رَجُلَيْنِ أَحَدُهُمَا أَبْكَمُ لَا يَقْدِرُ
عَلَى شَيْءٍ وَهُوَ كَلٌّ عَلَى مَوْلَاهُ أَيْنَمَا يُوَجِّهْهُ
لَا يَأْتِ بِخَيْرٍ هَلْ يَسْتَوِي هُوَ وَمَنْ يَأْمُرُ
بِالْعَدْلِ وَهُوَ عَلَى صِرَاطٍ مُسْتَقِيمٍ﴾
  &lt;&#x2F;div&gt;
  
  &lt;p class=&quot;mt-4 font-mono text-sm text-center text-teal-700 dark:text-teal-400&quot; dir=&quot;ltr&quot;&gt;
    &amp;#x5B; النحل : ٧٦ &amp;#x5D;
  &lt;&#x2F;p&gt;
  
  
&lt;&#x2F;div&gt;

&lt;div class=&quot;py-6 px-8 my-8 rounded-lg border shadow-sm quran-verse border-teal-600&#x2F;40 bg-teal-50&#x2F;30 dark:bg-teal-950&#x2F;20&quot;
  dir=&quot;rtl&quot; style=&quot;font-family: &#x27;Amiri Quran&#x27;, serif; font-size: 1.6rem;&quot;&gt;
  &lt;div class=&quot;leading-loose text-right quran-text text-slate-800 dark:text-slate-100&quot;&gt;
    ﴿﴿شَاكِرًا لِأَنْعُمِهِ اجْتَبَاهُ وَهَدَاهُ إِلَى صِرَاطٍ مُسْتَقِيمٍ﴾
  &lt;&#x2F;div&gt;
  
  &lt;p class=&quot;mt-4 font-mono text-sm text-center text-teal-700 dark:text-teal-400&quot; dir=&quot;ltr&quot;&gt;
    &amp;#x5B; النحل : ١٢١ &amp;#x5D;
  &lt;&#x2F;p&gt;
  
  
&lt;&#x2F;div&gt;

&lt;div class=&quot;py-6 px-8 my-8 rounded-lg border shadow-sm quran-verse border-teal-600&#x2F;40 bg-teal-50&#x2F;30 dark:bg-teal-950&#x2F;20&quot;
  dir=&quot;rtl&quot; style=&quot;font-family: &#x27;Amiri Quran&#x27;, serif; font-size: 1.6rem;&quot;&gt;
  &lt;div class=&quot;leading-loose text-right quran-text text-slate-800 dark:text-slate-100&quot;&gt;
    ﴿وَإِنَّ اللَّهَ رَبِّي وَرَبُّكُمْ فَاعْبُدُوهُ هَذَا صِرَاطٌ مُسْتَقِيمٌ﴾
  &lt;&#x2F;div&gt;
  
  &lt;p class=&quot;mt-4 font-mono text-sm text-center text-teal-700 dark:text-teal-400&quot; dir=&quot;ltr&quot;&gt;
    &amp;#x5B; مريم : ٣٦ &amp;#x5D;
  &lt;&#x2F;p&gt;
  
  
&lt;&#x2F;div&gt;

&lt;div class=&quot;py-6 px-8 my-8 rounded-lg border shadow-sm quran-verse border-teal-600&#x2F;40 bg-teal-50&#x2F;30 dark:bg-teal-950&#x2F;20&quot;
  dir=&quot;rtl&quot; style=&quot;font-family: &#x27;Amiri Quran&#x27;, serif; font-size: 1.6rem;&quot;&gt;
  &lt;div class=&quot;leading-loose text-right quran-text text-slate-800 dark:text-slate-100&quot;&gt;
    ﴿وَلِيَعْلَمَ الَّذِينَ أُوتُوا الْعِلْمَ أَنَّهُ الْحَقُّ مِنْ رَبِّكَ
فَيُؤْمِنُوا بِهِ فَتُخْبِتَ لَهُ قُلُوبُهُمْ وَإِنَّ اللَّهَ
لَهَادِ الَّذِينَ آمَنُوا إِلَى صِرَاطٍ مُسْتَقِيمٍ﴾
  &lt;&#x2F;div&gt;
  
  &lt;p class=&quot;mt-4 font-mono text-sm text-center text-teal-700 dark:text-teal-400&quot; dir=&quot;ltr&quot;&gt;
    &amp;#x5B; الحج : ٥٤ &amp;#x5D;
  &lt;&#x2F;p&gt;
  
  
&lt;&#x2F;div&gt;

&lt;div class=&quot;py-6 px-8 my-8 rounded-lg border shadow-sm quran-verse border-teal-600&#x2F;40 bg-teal-50&#x2F;30 dark:bg-teal-950&#x2F;20&quot;
  dir=&quot;rtl&quot; style=&quot;font-family: &#x27;Amiri Quran&#x27;, serif; font-size: 1.6rem;&quot;&gt;
  &lt;div class=&quot;leading-loose text-right quran-text text-slate-800 dark:text-slate-100&quot;&gt;
    ﴿وَإِنَّكَ لَتَدْعُوهُمْ إِلَى صِرَاطٍ مُسْتَقِيمٍ﴾
  &lt;&#x2F;div&gt;
  
  &lt;p class=&quot;mt-4 font-mono text-sm text-center text-teal-700 dark:text-teal-400&quot; dir=&quot;ltr&quot;&gt;
    &amp;#x5B; المؤمنون : ٧٣ &amp;#x5D;
  &lt;&#x2F;p&gt;
  
  
&lt;&#x2F;div&gt;

&lt;div class=&quot;py-6 px-8 my-8 rounded-lg border shadow-sm quran-verse border-teal-600&#x2F;40 bg-teal-50&#x2F;30 dark:bg-teal-950&#x2F;20&quot;
  dir=&quot;rtl&quot; style=&quot;font-family: &#x27;Amiri Quran&#x27;, serif; font-size: 1.6rem;&quot;&gt;
  &lt;div class=&quot;leading-loose text-right quran-text text-slate-800 dark:text-slate-100&quot;&gt;
    ﴿لَقَدْ أَنْزَلْنَا آيَاتٍ مُبَيِّنَاتٍ وَاللَّهُ
يَهْدِي مَنْ يَشَاءُ إِلَى صِرَاطٍ مُسْتَقِيمٍ﴾
  &lt;&#x2F;div&gt;
  
  &lt;p class=&quot;mt-4 font-mono text-sm text-center text-teal-700 dark:text-teal-400&quot; dir=&quot;ltr&quot;&gt;
    &amp;#x5B; النور : ٤٦ &amp;#x5D;
  &lt;&#x2F;p&gt;
  
  
&lt;&#x2F;div&gt;

&lt;div class=&quot;py-6 px-8 my-8 rounded-lg border shadow-sm quran-verse border-teal-600&#x2F;40 bg-teal-50&#x2F;30 dark:bg-teal-950&#x2F;20&quot;
  dir=&quot;rtl&quot; style=&quot;font-family: &#x27;Amiri Quran&#x27;, serif; font-size: 1.6rem;&quot;&gt;
  &lt;div class=&quot;leading-loose text-right quran-text text-slate-800 dark:text-slate-100&quot;&gt;
    ﴿عَلَى صِرَاطٍ مُسْتَقِيمٍ﴾
  &lt;&#x2F;div&gt;
  
  &lt;p class=&quot;mt-4 font-mono text-sm text-center text-teal-700 dark:text-teal-400&quot; dir=&quot;ltr&quot;&gt;
    &amp;#x5B; يس : ٤ &amp;#x5D;
  &lt;&#x2F;p&gt;
  
  
